# Example environment file.
#
# WHY THIS FILE EXISTS
# --------------------
# Documents every environment variable the app reads. Copy to `.env` for local
# (non-Docker) runs: `cp .env.example .env`.
#
# IMPORTANT: `docker compose up` does NOT require a .env file — compose injects
# these values itself (see docker-compose.yml), pointing the hosts at the
# service names `postgres`/`redis`. The localhost defaults below are for running
# the API/worker directly on your machine against locally-running services.

# --- Application ---
APP_NAME=transaction-pipeline
APP_ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# --- PostgreSQL ---
# Use `localhost` for local runs; Docker Compose overrides this to `postgres`.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=transactions

# --- Redis ---
# Use `localhost` for local runs; Docker Compose overrides this to `redis`.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- Celery (optional) ---
# Leave blank to default to the Redis URL built from the values above.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# --- Uploads ---
# Local dev: a writable relative dir. Docker Compose uses /data/uploads (a volume).
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=5242880

# --- Gemini / LLM ---
# Leave GEMINI_API_KEY blank to run without the LLM (graceful degradation):
# classification rows are marked llm_failed and the narrative/risk are left null.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
LLM_BATCH_SIZE=25
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0
